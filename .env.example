# ── Required ──────────────────────────────────────────────────────────────────
# Public canonical origin used for metadata, sitemap, robots, and share cards.
# Vercel: set to your production domain or your-project-name.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-project-name.vercel.app

# ── Optional monitoring (add on Vercel dashboard after first deploy) ──────────
# NEXT_PUBLIC_VERCEL_ANALYTICS_ID=
# NEXT_PUBLIC_SENTRY_DSN=

# ── Vercel deployment checklist ───────────────────────────────────────────────
# 1. Set NEXT_PUBLIC_SITE_URL to your real domain in Vercel Environment Variables
# 2. Framework preset: Next.js (auto-detected)
# 3. Build command: npm run build   Output dir: .next
# 4. Node.js version: 20.x
